# ── Base de données — Prisma Postgres ─────────────────────────────────────────
DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"

# ── Application ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
NEXT_PUBLIC_ROOT_DOMAIN="your-project.vercel.app"
NEXT_PUBLIC_ADMIN_DOMAIN="your-project.vercel.app"

# ── Better Auth ────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="https://your-project.vercel.app"

# ── Uploadthing ────────────────────────────────────────────────────────────────
UPLOADTHING_TOKEN=""

# ── Email SMTP (Gmail) ─────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ── Seed admin initial ─────────────────────────────────────────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# ── Vercel API (domaines perso — phase 2) ──────────────────────────────────────
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
